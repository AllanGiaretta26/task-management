# Gradle build outputs and caches
.gradle/
build/
app/build/
app/bin/

# Database credentials (sensitive — NEVER version this file)
**/database.properties

# Logs
*.log
logs/
app/logs/

# IDE-specific files
.idea/
*.iml
*.iws
*.ipr
.project
.settings/
.classpath
.vscode/
.qwen/

# OS generated files
.DS_Store
Thumbs.db
Desktop.ini
ehthumbs.db
ehthumbs_vista.db

# Java compiled classes
**/*.class

# Package files
*.jar
*.war
*.ear
*.zip
*.tar.gz
*.rar

# Gradle wrapper JAR must be tracked (needed to bootstrap Gradle without a local install)
!gradle/wrapper/gradle-wrapper.jar

# Environment variables
.env
.env.local
*.env

# JVM crash logs
hs_err_pid*
replay_pid*

# H2 database files (used in tests — never commit)
*.mv.db
*.trace.db

# Temporary files
*.tmp
*.swp
*~